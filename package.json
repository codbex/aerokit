{
  "name": "codbex-docgen",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs --port 8080",
    "docs:preview": "vitepress preview docs --port 8080",
    "docs:generate-typedoc": "typedoc",
    "docs:generate": "rm -rf docs/sdk && node --loader ts-node/esm src/index.ts",
    "docs:api": "typedoc"
  },
  "dependencies": {
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.4.0"
  }
}